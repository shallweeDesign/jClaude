{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "SCSS: Watch",
      "type": "shell",
      "command": "~/dart-sass/sass _output/scss/main.scss _output/style.css --no-source-map --watch --quiet",
      "group": "build",
      "isBackground": true,
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "SCSS: Build",
      "type": "shell",
      "command": "~/dart-sass/sass _output/scss/main.scss _output/style.css --no-source-map --quiet",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "silent"
      }
    },
    {
      "label": "Deploy to GitHub Pages",
      "type": "shell",
      "command": "./deploy.sh",
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
